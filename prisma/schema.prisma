// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Camper {
  id             String   @id @default(cuid())
  slug           String   @unique
  brand          String   // Añadido: Marca (ej. Volkswagen)
  model          String   // Puesto en minúscula
  year           Int?     // Añadido: Año del vehículo
  mileage        Int?     // Añadido: Kilometraje
  description    String?  // Cambiado de 'Comentario'
  contactRequest String?  // Puesto en minúscula
  price          Int      // Guardado idealmente en céntimos, o cambiar a Float/Decimal
  imageUrl       String?  // Cambiado a imageUrl (o podrías usar images String[])
  isAvailable    Boolean  @default(true) // Añadido: ¿Está disponible?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt // Añadido: Auto-actualiza la fecha al modificar
  comments       Comment[]
}

enum Role {
  USER
  EDITOR
  ADMIN
}

// User que puede ser Admin, Staff (Editor) o Usuario
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?
  profileImg  String?
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
}

// Puede estar relacionado con un camper o otro comment
model Comment{
  id          String   @id @default(cuid())
  text        String
  rating      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String   
  user        User     @relation(fields: [userId], references: [id])
  camperId    String? 
  camper      Camper?  @relation(fields: [camperId], references: [id])
  comentID    String?
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
